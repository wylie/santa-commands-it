---
import {
  createPublicExcerpt,
  PUBLIC_RULING_CARD_EXCERPT_LIMITS,
  type PublicCommandsDiscoveryRuling,
} from '@/utils/publicCommands';
import { buildRulingPath } from '@/utils/rulingPages';
import {
  formatPublicCardTimestamp,
  getPublicDecisionLabel,
  getPublicDecisionSupportingText,
  type PublicRuling,
} from '@/utils/rulings';

interface Props {
  ruling: PublicRuling | PublicCommandsDiscoveryRuling;
  variant?: 'compact' | 'browse';
}

const { ruling, variant = 'browse' } = Astro.props;
const excerptLimits = PUBLIC_RULING_CARD_EXCERPT_LIMITS[variant];
const requestText = createPublicExcerpt(
  ruling.requestText,
  excerptLimits.request,
);
const responseText = createPublicExcerpt(
  ruling.santaResponse,
  excerptLimits.response,
);
const cardHeadingId = `public-ruling-card-title-${ruling.publicId}`;
const responseLabelId = `public-ruling-card-response-${ruling.publicId}`;
const actionLabel = `Read Santa's answer to ${ruling.displayName}'s request`;
---

<article
  class:list={['public-ruling-card', `public-ruling-card--${variant}`]}
  data-public-ruling-card
  data-ruling-id={ruling.publicId}
  data-decision={ruling.decision}
  aria-labelledby={cardHeadingId}
>
  <header class="public-ruling-card__header">
    <div class="public-ruling-card__status-group">
      <div class="public-ruling-card__status-line">
        <p class="public-ruling-card__decision" data-decision={ruling.decision}>
          {getPublicDecisionLabel(ruling.decision)}
        </p>
        {
          ruling.isFeatured && (
            <p class="public-ruling-card__badge" data-featured-badge>
              Featured
            </p>
          )
        }
      </div>
      <p class="public-ruling-card__status-note">
        {getPublicDecisionSupportingText(ruling.decision)}
      </p>
    </div>
    <time class="public-ruling-card__time" datetime={ruling.createdAt}>
      {formatPublicCardTimestamp(ruling.createdAt)}
    </time>
  </header>
  <div class="public-ruling-card__body">
    <h3
      id={cardHeadingId}
      class="public-ruling-card__context"
      data-public-ruling-context
    >
      <span class="public-ruling-card__name">{ruling.displayName}</span> asked Santa...
    </h3>
    <blockquote
      class="public-ruling-card__request-block"
      data-public-ruling-request
    >
      <p class="public-ruling-card__request">{requestText}</p>
    </blockquote>
    <section
      class="public-ruling-card__response-block"
      aria-labelledby={responseLabelId}
      data-public-ruling-response
    >
      <p id={responseLabelId} class="public-ruling-card__response-label">
        Santa answered
      </p>
      <p class="public-ruling-card__response">{responseText}</p>
    </section>
  </div>
  <p class="public-ruling-card__action">
    <a
      class="public-ruling-card__link"
      href={buildRulingPath(ruling.publicId)}
      aria-label={actionLabel}
    >
      READ SANTA&apos;S ANSWER
    </a>
  </p>
</article>
