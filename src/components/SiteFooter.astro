---
import { SITE_OWNER, SITE_TITLE } from '@/config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="site-footer__primary">
    <span>{SITE_TITLE}</span>
    <span>&copy; {year}</span>
  </p>
  <p class="site-footer__secondary">
    A humorous fictional experience. Santa remains theatrically unreasonable.
  </p>
  <p class="site-footer__tertiary">
    A project from{' '}
    {
      SITE_OWNER.url ? (
        <a href={SITE_OWNER.url} target="_blank">{SITE_OWNER.name}</a>
      ) : (
        <span>{SITE_OWNER.name}</span>
      )
    }
  </p>
</footer>
