---
import { publicSantaUiSettings } from '@/config/public-santa-ui';
import PublicRulingCard from '@/components/PublicRulingCard.astro';
import { buildPublicCommandsPath } from '@/utils/publicCommands';
import type { PublicRuling } from '@/utils/rulings';

interface Props {
  rulings?: PublicRuling[];
  unavailableMessage?: string | null;
}

const { rulings = [], unavailableMessage = null } = Astro.props;
const hasRulings = rulings.length > 0;
---

<section
  class="recent-rulings"
  aria-labelledby="recent-rulings-title"
  data-recent-rulings
  data-limit={publicSantaUiSettings.recentRulings.visibleLimit}
>
  <div class="section-heading">
    <h2 id="recent-rulings-title">Santa&apos;s Latest Commands</h2>
    <p>
      <a class="text-link" href={buildPublicCommandsPath()}>
        VIEW ALL COMMANDS
      </a>
    </p>
  </div>

  {
    unavailableMessage ? (
      <div class="recent-rulings__empty" data-recent-unavailable>
        <p>{unavailableMessage}</p>
      </div>
    ) : hasRulings ? (
      <ol class="recent-rulings__list" data-recent-list>
        {rulings.map((ruling) => (
          <li class="recent-rulings__item" data-ruling-id={ruling.publicId}>
            <PublicRulingCard ruling={ruling} variant="compact" />
          </li>
        ))}
      </ol>
    ) : (
      <div class="recent-rulings__empty" data-recent-empty>
        <p>Santa has not made any public commands yet.</p>
        <p class="recent-rulings__note">
          Future approvals and coal decrees will appear here once the workshop
          ledger is ready.
        </p>
        <p>
          <a class="text-link" href={buildPublicCommandsPath()}>
            BROWSE COMMANDS
          </a>
        </p>
      </div>
    )
  }
  <p
    class="sr-only"
    aria-live="polite"
    aria-atomic="true"
    data-recent-announcement
  >
  </p>
</section>
