---
import RulingReportForm from '@/components/RulingReportForm.astro';
import type { PublicRuling } from '@/utils/rulings';
import { buildRulingSharePayload } from '@/utils/rulingPages';

interface Props {
  ruling: PublicRuling;
  canonicalUrl: string;
}

const { ruling, canonicalUrl } = Astro.props;
const sharePayload = buildRulingSharePayload(ruling, canonicalUrl);
---

<section class="ruling-actions" aria-label="Public ruling actions">
  <div class="ruling-actions__group ruling-actions__group--sharing">
    <p class="ruling-actions__heading">Share this ruling</p>
    <div
      class="ruling-share"
      data-ruling-share
      data-url={canonicalUrl}
      data-title={sharePayload.title}
      data-text={sharePayload.text}
    >
      <div class="ruling-share__actions">
        <button
          type="button"
          class="button-secondary"
          data-native-share
          data-default-label="SHARE"
          data-pending-label="SHARING..."
          hidden
          aria-label="Share this Santa ruling"
        >
          SHARE
        </button>
        <button
          type="button"
          class="button-secondary"
          data-copy-link
          data-default-label="COPY LINK"
          data-pending-label="COPYING..."
          data-success-label="LINK COPIED"
          aria-label="Copy a link to this Santa ruling"
        >
          COPY LINK
        </button>
      </div>
      <p class="ruling-share__hint">
        Share or copy the permanent public link for this ruling.
      </p>
      <div
        class="ruling-share__manual"
        data-manual-copy
        hidden
        aria-label="Manual copy link"
      >
        <label class="sr-only" for={`manual-copy-link-${ruling.publicId}`}>
          Canonical public ruling link
        </label>
        <input
          id={`manual-copy-link-${ruling.publicId}`}
          class="ruling-share__manual-input"
          type="text"
          value={canonicalUrl}
          readonly
          data-manual-copy-input
        />
      </div>
      <p
        class="ruling-share__status"
        role="status"
        aria-live="polite"
        aria-atomic="true"
        data-share-status
      >
      </p>
      <noscript>
        <p class="ruling-share__noscript">
          Copy or open the permanent ruling link:
          <a class="text-link" href={canonicalUrl}> OPEN SHAREABLE LINK </a>
        </p>
      </noscript>
    </div>
  </div>

  <div class="ruling-actions__group ruling-actions__group--secondary">
    <a class="text-link" href="/commands"> BACK TO REQUESTS </a>
  </div>

  <div class="ruling-actions__group ruling-actions__group--report">
    <RulingReportForm publicId={ruling.publicId} />
  </div>
</section>

<script>
  import { initRulingShareActions } from '@/scripts/ruling-share-actions';

  initRulingShareActions();
</script>
