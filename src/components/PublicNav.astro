---
import { PUBLIC_COMMANDS_PATH } from '@/utils/publicCommands';

interface Props {
  current?: 'ask-santa' | 'browse-requests';
}

const { current } = Astro.props;
---

<nav class="public-nav" aria-label="Public navigation">
  <a
    href="/#ask-santa"
    class:list={['public-nav__link', current === 'ask-santa' && 'is-current']}
    aria-current={current === 'ask-santa' ? 'page' : undefined}
  >
    ASK SANTA
  </a>
  <a
    href={PUBLIC_COMMANDS_PATH}
    class:list={[
      'public-nav__link',
      current === 'browse-requests' && 'is-current',
    ]}
    aria-current={current === 'browse-requests' ? 'page' : undefined}
  >
    BROWSE REQUESTS
  </a>
</nav>
