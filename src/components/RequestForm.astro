---
import { REQUEST_LIMITS } from '@/config/request';
import { formatCharacterCount } from '@/utils/characterCount';

const { nameMaxLength, requestMaxLength } = REQUEST_LIMITS;
const initialCount = formatCharacterCount(0, requestMaxLength);
---

<section class="request-panel" aria-label="Santa request form">
  <form class="request-form" data-request-form novalidate>
    <div class="request-form__trap" aria-hidden="true">
      <label for="visitor-website">Website</label>
      <input
        id="visitor-website"
        name="website"
        type="text"
        tabindex="-1"
        autocomplete="off"
        data-request-trap
      />
    </div>

    <div class="request-form__field">
      <label for="visitor-name">What should Santa call you?</label>
      <input
        id="visitor-name"
        name="visitorName"
        type="text"
        maxlength={nameMaxLength}
        autocomplete="nickname"
        aria-describedby="visitor-name-hint visitor-name-error"
        data-request-name
      />
      <p id="visitor-name-hint" class="request-form__hint">
        A first name or nickname is perfect.
      </p>
      <p
        id="visitor-name-error"
        class="request-form__error"
        data-field-error="name"
        hidden
      >
      </p>
    </div>

    <div class="request-form__field">
      <div class="request-form__label-row">
        <label for="visitor-request">What would you like from Santa?</label>
        <p
          id="request-counter"
          class="request-form__counter"
          data-request-counter
          data-state="normal"
        >
          {initialCount}
        </p>
      </div>
      <textarea
        id="visitor-request"
        name="visitorRequest"
        maxlength={requestMaxLength}
        rows="6"
        aria-describedby="visitor-request-hint request-counter visitor-request-error"
        data-request-input></textarea>
      <p id="visitor-request-hint" class="request-form__hint">
        Keep it kind, playful, and suitable for Santa&apos;s workshop.
      </p>
      <p
        id="visitor-request-error"
        class="request-form__error"
        data-field-error="request"
        hidden
      >
      </p>
    </div>

    <div class="request-form__actions">
      <p class="request-form__note">
        Approved requests and coal rulings may appear publicly below.
      </p>
      <div class="request-form__action-row">
        <button type="submit" class="button-command" data-request-submit>
          ASK SANTA
        </button>
        <a class="button-link-secondary" data-request-permalink hidden>
          VIEW &amp; SHARE
        </a>
      </div>
      <p
        id="request-status"
        class="request-form__status"
        role="status"
        aria-live="polite"
        data-request-status
      >
      </p>
    </div>
  </form>
</section>

<script>
  import { initSantaRequestFlow } from '@/scripts/santa-request-flow';

  initSantaRequestFlow();
</script>
