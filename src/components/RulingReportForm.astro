---
import { reportReasons } from '@/config/reports';
import { securitySettings } from '@/config/security';

interface Props {
  publicId: string;
}

const { publicId } = Astro.props;
---

<section class="ruling-report" data-report-root data-public-id={publicId}>
  <button
    type="button"
    class="ruling-report__toggle"
    aria-expanded="false"
    data-report-toggle
  >
    REPORT THIS COMMAND
  </button>

  <div class="ruling-report__panel" data-report-panel hidden>
    <form class="ruling-report__form" data-report-form novalidate>
      <div class="ruling-report__field">
        <label for={`report-reason-${publicId}`}
          >Why are you reporting this?</label
        >
        <select
          id={`report-reason-${publicId}`}
          name="reportReason"
          aria-describedby={`report-reason-error-${publicId}`}
          data-report-reason
        >
          <option value="">Choose a reason</option>
          {
            reportReasons.map((reason) => (
              <option value={reason.value}>{reason.label}</option>
            ))
          }
        </select>
        <p
          id={`report-reason-error-${publicId}`}
          class="ruling-report__error"
          data-report-error="reason"
          hidden
        >
        </p>
      </div>

      <div class="ruling-report__field">
        <div class="ruling-report__label-row">
          <label for={`report-note-${publicId}`}>Optional note</label>
          <p class="ruling-report__counter" data-report-counter>
            0 / {securitySettings.reports.noteMaxLength}
          </p>
        </div>
        <textarea
          id={`report-note-${publicId}`}
          name="reportNote"
          rows="4"
          maxlength={securitySettings.reports.noteMaxLength}
          aria-describedby={`report-note-hint-${publicId} report-note-error-${publicId}`}
          data-report-note></textarea>
        <p id={`report-note-hint-${publicId}`} class="ruling-report__hint">
          You may add a short note. Do not include personal information.
        </p>
        <p
          id={`report-note-error-${publicId}`}
          class="ruling-report__error"
          data-report-error="note"
          hidden
        >
        </p>
      </div>

      <div class="ruling-report__actions">
        <button type="submit" class="button-secondary" data-report-submit>
          SUBMIT REPORT
        </button>
        <button type="button" class="ruling-report__cancel" data-report-cancel>
          CANCEL
        </button>
      </div>
    </form>
  </div>

  <p
    class="ruling-report__status"
    role="status"
    aria-live="polite"
    data-report-status
  >
  </p>
</section>

<script>
  import { initRulingReportFlow } from '@/scripts/ruling-report-flow';

  initRulingReportFlow();
</script>
