---
import RulingShareActions from '@/components/RulingShareActions.astro';
import PublicShell from '@/components/PublicShell.astro';
import SeasonalPublicNotice from '@/components/SeasonalPublicNotice.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicSeasonalPresentation } from '@/server/config/service';
import { getSiteUrl } from '@/server/env';
import {
  getPublicRulingForHeaders,
  RULING_LOOKUP_ERROR_MESSAGE,
} from '@/server/rulings/service';
import { buildRulingSocialMetadata } from '@/utils/rulingPages';
import { formatRulingTimestamp } from '@/utils/rulings';

const publicId = Astro.params.publicId ?? '';
const rulingResult = await getPublicRulingForHeaders(
  publicId,
  Astro.request.headers,
);

const siteUrl = getSiteUrl();
const seasonalPresentation = await getPublicSeasonalPresentation(
  Astro.request.headers,
);

let title: string;
let description: string;
let canonicalUrl: string | null = null;
let socialImageUrl: string | null = null;
let socialImageAlt: string | undefined;
let robots: string | undefined;
let ogType: 'website' | 'article' = 'website';
let twitterCard: 'summary' | 'summary_large_image' = 'summary';

if (rulingResult.status === 'ok') {
  const socialMetadata = buildRulingSocialMetadata(rulingResult.ruling, {
    siteUrl,
    requestUrl: Astro.url,
  });

  title = socialMetadata.title;
  description = socialMetadata.description;
  canonicalUrl = socialMetadata.canonicalUrl;
  socialImageUrl = socialMetadata.imageUrl;
  socialImageAlt = socialMetadata.imageAlt;
  ogType = 'article';
  twitterCard = socialMetadata.twitterCard;
} else if (rulingResult.status === 'not-found') {
  title = 'Santa Cannot Find That Request';
  description =
    'Santa could not find that request. Return to the homepage and ask Santa for something else.';
  robots = 'noindex, nofollow';
  Astro.response.status = 404;
} else {
  title = "Santa's Workshop Is Having A Small Mishap";
  description =
    "Santa's workshop is having a small mishap. Please try again in a moment.";
  robots = 'noindex, nofollow';
  Astro.response.status = 503;
}
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogType={ogType}
  robots={robots}
  socialImageUrl={socialImageUrl}
  socialImageAlt={socialImageAlt}
  socialImageType={socialImageUrl ? 'image/png' : undefined}
  socialImageWidth={socialImageUrl ? 1200 : undefined}
  socialImageHeight={socialImageUrl ? 630 : undefined}
  twitterCard={twitterCard}
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main id="main-content" class="page-shell">
    <PublicShell
      current="browse-requests"
      seasonalMode={seasonalPresentation.mode}
    >
      <SeasonalPublicNotice
        presentation={{
          ...seasonalPresentation,
          countdown:
            rulingResult.status === 'ok'
              ? seasonalPresentation.countdown
              : null,
        }}
        variant="compact"
      />
      {
        rulingResult.status === 'ok' ? (
          <article
            class="ruling-card"
            data-ruling-page
            data-decision={rulingResult.ruling.decision}
          >
            <p class="ruling-card__eyebrow">Santa has spoken</p>
            {rulingResult.ruling.isFeatured && (
              <p class="ruling-card__featured" data-featured-badge>
                Featured
              </p>
            )}
            <p class="ruling-card__intro">
              <strong>{rulingResult.ruling.displayName}</strong> asked Santa:
            </p>
            <blockquote class="ruling-card__request">
              <p>{rulingResult.ruling.requestText}</p>
            </blockquote>
            <p class="ruling-card__result-type">
              {rulingResult.ruling.decision === 'approved'
                ? 'Approved ruling'
                : 'Coal ruling'}
            </p>
            <h1 id="ruling-page-title" class="ruling-card__title">
              {rulingResult.ruling.decision === 'approved'
                ? 'SANTA COMMANDS IT!'
                : 'COAL'}
            </h1>
            <p class="ruling-card__response">
              {rulingResult.ruling.santaResponse}
            </p>
            <p class="ruling-card__date">
              Issued{' '}
              <time datetime={rulingResult.ruling.createdAt}>
                {formatRulingTimestamp(rulingResult.ruling.createdAt)}
              </time>
            </p>
            {canonicalUrl && (
              <RulingShareActions
                ruling={rulingResult.ruling}
                canonicalUrl={canonicalUrl}
              />
            )}
          </article>
        ) : rulingResult.status === 'not-found' ? (
          <section class="ruling-card ruling-card--message">
            <p class="ruling-card__eyebrow">Santa has spoken</p>
            <h1 id="ruling-page-title" class="ruling-card__title">
              SANTA CANNOT FIND THAT REQUEST.
            </h1>
            <p class="ruling-card__response">
              Santa may have misplaced it somewhere in the workshop.
            </p>
            <p class="ruling-card__return">
              <a class="text-link" href="/commands">
                BACK TO REQUESTS
              </a>
            </p>
          </section>
        ) : (
          <section class="ruling-card ruling-card--message">
            <p class="ruling-card__eyebrow">Santa has spoken</p>
            <h1 id="ruling-page-title" class="ruling-card__title">
              SANTA&apos;S WORKSHOP IS HAVING A SMALL MISHAP.
            </h1>
            <p class="ruling-card__response">{RULING_LOOKUP_ERROR_MESSAGE}</p>
            <p class="ruling-card__return">
              <a class="text-link" href="/commands">
                BACK TO REQUESTS
              </a>
            </p>
          </section>
        )
      }
    </PublicShell>
  </main>
</BaseLayout>
