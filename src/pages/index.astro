---
import RequestForm from '@/components/RequestForm.astro';
import RecentRulings from '@/components/RecentRulings.astro';
import PublicNav from '@/components/PublicNav.astro';
import SantaPortrait from '@/components/SantaPortrait.astro';
import SantaSpeechBubble from '@/components/SantaSpeechBubble.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { listRecentRulingsForHeaders } from '@/server/rulings/service';

const recentRulingsResult = await listRecentRulingsForHeaders(
  Astro.request.headers,
);
---

<BaseLayout
  title="Santa Commands It! | A cheerful command from Santa"
  description="A warm, theatrical holiday homepage where visitors can ask Santa for a server-backed ruling that may be approved, blocked, or awarded coal."
  canonicalPath="/"
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main id="main-content" class="page-shell">
    <section class="hero" aria-labelledby="opening-panel-title">
      <div class="hero__left-rail">
        <h1 class="sr-only">Santa Commands It!</h1>
        <PublicNav current="home" />
        <div class="hero__portrait">
          <SantaPortrait />
        </div>
        <SiteFooter />
      </div>
      <div class="hero__content">
        <SantaSpeechBubble />
        <RequestForm />
        <RecentRulings
          rulings={recentRulingsResult.status === 'ok'
            ? recentRulingsResult.rulings
            : []}
          unavailableMessage={recentRulingsResult.status === 'unavailable'
            ? recentRulingsResult.message
            : null}
        />
      </div>
    </section>
  </main>
</BaseLayout>
