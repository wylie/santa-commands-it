---
import FeaturedRulings from '@/components/FeaturedRulings.astro';
import PublicShell from '@/components/PublicShell.astro';
import RequestForm from '@/components/RequestForm.astro';
import RecentRulings from '@/components/RecentRulings.astro';
import SantaSpeechBubble from '@/components/SantaSpeechBubble.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getHomepageSeasonalGreeting } from '@/server/config/service';
import {
  listFeaturedRulingsForHeaders,
  listRecentRulingsForHeaders,
} from '@/server/rulings/service';

const [recentRulingsResult, featuredRulingsResult, seasonalGreeting] =
  await Promise.all([
    listRecentRulingsForHeaders(Astro.request.headers),
    listFeaturedRulingsForHeaders(Astro.request.headers),
    getHomepageSeasonalGreeting(Astro.request.headers),
  ]);
---

<BaseLayout
  title="Santa Commands It! | A cheerful command from Santa"
  description="A warm, theatrical holiday homepage where visitors can ask Santa for a server-backed ruling that may be approved, blocked, or awarded coal."
  canonicalPath="/"
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main id="main-content" class="page-shell">
    <PublicShell current="ask-santa">
      <h1 class="sr-only">Santa Commands It!</h1>
      <SantaSpeechBubble />
      {
        seasonalGreeting && (
          <section class="seasonal-greeting" aria-label="Seasonal greeting">
            <p>{seasonalGreeting}</p>
          </section>
        )
      }
      <RequestForm />
      <FeaturedRulings
        rulings={featuredRulingsResult.status === 'ok'
          ? featuredRulingsResult.rulings
          : []}
      />
      <RecentRulings
        rulings={recentRulingsResult.status === 'ok'
          ? recentRulingsResult.rulings
          : []}
        unavailableMessage={recentRulingsResult.status === 'unavailable'
          ? recentRulingsResult.message
          : null}
      />
    </PublicShell>
  </main>
</BaseLayout>
