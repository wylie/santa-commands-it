---
import PublicShell from '@/components/PublicShell.astro';
import PublicRulingCard from '@/components/PublicRulingCard.astro';
import SeasonalPublicNotice from '@/components/SeasonalPublicNotice.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicSeasonalPresentation } from '@/server/config/service';
import { listPublicCommandsForHeaders } from '@/server/rulings/service';
import {
  PUBLIC_COMMANDS_PATH,
  buildPublicCommandsPagePath,
  buildPublicCommandsPath,
  getPublicCommandsSummary,
  hasPublicCommandsParameters,
  parsePublicCommandsQuery,
} from '@/utils/publicCommands';

const query = parsePublicCommandsQuery(Astro.url.searchParams);
const normalizedCommandsPath = buildPublicCommandsPath(query);

if (`${Astro.url.pathname}${Astro.url.search}` !== normalizedCommandsPath) {
  return Astro.redirect(normalizedCommandsPath, 302);
}

const hasDiscoveryParameters = hasPublicCommandsParameters(
  Astro.url.searchParams,
);
const commandsResult = await listPublicCommandsForHeaders(
  query,
  Astro.request.headers,
);
const seasonalPresentation = await getPublicSeasonalPresentation(
  Astro.request.headers,
);

if (commandsResult.status === 'unavailable') {
  Astro.response.status = 503;
  Astro.response.headers.set('Cache-Control', 'no-store');
}

const isUnavailable = commandsResult.status === 'unavailable';
const rulings = commandsResult.status === 'ok' ? commandsResult.rulings : [];
const total = commandsResult.status === 'ok' ? commandsResult.total : 0;
const totalPages =
  commandsResult.status === 'ok' ? commandsResult.totalPages : 1;
const hasResults = rulings.length > 0;
const summary = getPublicCommandsSummary(total, query);
const previousPagePath =
  query.page > 1 ? buildPublicCommandsPagePath(query, query.page - 1) : null;
const nextPagePath =
  commandsResult.status === 'ok' && query.page < totalPages
    ? buildPublicCommandsPagePath(query, query.page + 1)
    : null;
const firstPagePath = buildPublicCommandsPath({ ...query, page: 1 });
const emptyTitle =
  total === 0 &&
  !query.search &&
  query.decision === 'all' &&
  !query.featuredOnly
    ? "Santa hasn't answered any public requests yet."
    : total === 0 &&
        !query.search &&
        query.decision === 'all' &&
        query.featuredOnly
      ? "Santa hasn't featured any requests yet."
      : query.search
        ? query.featuredOnly
          ? 'No featured requests matched.'
          : 'No requests matched your search.'
        : query.decision === 'coal'
          ? query.featuredOnly
            ? 'No featured coal requests matched.'
            : 'No coal rulings are available right now.'
          : query.decision === 'approved'
            ? query.featuredOnly
              ? 'No featured approved requests matched.'
              : 'No approved requests are available right now.'
            : 'There are no requests on this page.';
const isBeyondAvailableResults = total > 0 && !hasResults;
---

<BaseLayout
  title="Requests Answered by Santa | Santa Commands It!"
  description="Browse public requests Santa has approved or answered with coal."
  canonicalPath={PUBLIC_COMMANDS_PATH}
  robots={hasDiscoveryParameters ? 'noindex, follow' : undefined}
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main id="main-content" class="page-shell" tabindex="-1">
    <PublicShell
      current="browse-requests"
      seasonalMode={seasonalPresentation.mode}
    >
      <SeasonalPublicNotice
        presentation={seasonalPresentation}
        variant="compact"
      />
      <header class="commands-header">
        <p class="commands-header__eyebrow">BROWSE REQUESTS</p>
        <h1>REQUESTS ANSWERED BY SANTA</h1>
        <p>Browse requests Santa has approved—or answered with coal.</p>
      </header>

      <section class="commands-panel" aria-labelledby="commands-filter-title">
        <h2 id="commands-filter-title">Find Requests</h2>
        <form
          class="commands-form"
          action={PUBLIC_COMMANDS_PATH}
          method="get"
          role="search"
        >
          <div class="commands-form__field commands-form__field--search">
            <label for="commands-search">Search public requests</label>
            <input
              id="commands-search"
              name="q"
              type="search"
              value={query.search}
              maxlength="80"
              autocomplete="off"
            />
          </div>
          <div class="commands-form__field">
            <label for="commands-decision">Decision</label>
            <select id="commands-decision" name="decision">
              <option value="all" selected={query.decision === 'all'}>
                All Requests
              </option>
              <option value="approved" selected={query.decision === 'approved'}>
                Approved
              </option>
              <option value="coal" selected={query.decision === 'coal'}>
                Coal
              </option>
            </select>
          </div>
          <div class="commands-form__field">
            <label for="commands-featured">Featured</label>
            <select id="commands-featured" name="featured">
              <option value="" selected={!query.featuredOnly}>
                All Requests
              </option>
              <option value="true" selected={query.featuredOnly}>
                Featured Only
              </option>
            </select>
          </div>
          <div class="commands-form__field">
            <label for="commands-sort">Sort</label>
            <select id="commands-sort" name="sort">
              <option value="newest" selected={query.sort === 'newest'}>
                Newest First
              </option>
              <option value="oldest" selected={query.sort === 'oldest'}>
                Oldest First
              </option>
            </select>
          </div>
          <div class="commands-form__actions">
            <button class="button-command" type="submit">APPLY</button>
            <a class="button-link-secondary" href={PUBLIC_COMMANDS_PATH}>
              CLEAR FILTERS
            </a>
          </div>
        </form>
      </section>

      <section
        class="commands-results"
        aria-labelledby="commands-results-title"
      >
        <div class="commands-results__heading">
          <h2 id="commands-results-title">Requests</h2>
          {!isUnavailable && <p>{summary}</p>}
        </div>

        {
          isUnavailable ? (
            <div class="commands-empty" data-commands-error>
              <h3>REQUESTS ANSWERED BY SANTA ARE TEMPORARILY UNAVAILABLE.</h3>
              <p>{commandsResult.message}</p>
              <p>
                <a class="text-link" href="/#ask-santa">
                  ASK SANTA
                </a>
              </p>
            </div>
          ) : hasResults ? (
            <ol class="commands-grid" data-commands-list>
              {rulings.map((ruling) => (
                <li>
                  <PublicRulingCard ruling={ruling} variant="browse" />
                </li>
              ))}
            </ol>
          ) : (
            <div class="commands-empty" data-commands-empty>
              <h3>
                {isBeyondAvailableResults
                  ? 'There are no requests on this page.'
                  : emptyTitle}
              </h3>
              <p>
                {isBeyondAvailableResults
                  ? 'Return to the first page to keep browsing these results.'
                  : query.featuredOnly
                    ? 'Try changing your search or filters.'
                    : 'Try a different search, clear the filters, or ask Santa for a new request.'}
              </p>
              <p class="commands-empty__actions">
                {isBeyondAvailableResults ? (
                  <a class="text-link" href={firstPagePath}>
                    GO TO PAGE 1
                  </a>
                ) : (
                  <a class="text-link" href={PUBLIC_COMMANDS_PATH}>
                    CLEAR FILTERS
                  </a>
                )}
                <a class="button-link-secondary" href="/#ask-santa">
                  ASK SANTA
                </a>
              </p>
            </div>
          )
        }

        {
          !isUnavailable && totalPages > 1 && (
            <nav class="commands-pagination" aria-label="Requests pagination">
              {previousPagePath ? (
                <a class="commands-pagination__link" href={previousPagePath}>
                  Previous
                </a>
              ) : (
                <span class="commands-pagination__disabled">Previous</span>
              )}
              {Array.from({ length: totalPages }, (_, index) => index + 1).map(
                (pageNumber) => (
                  <a
                    class="commands-pagination__link"
                    href={buildPublicCommandsPagePath(query, pageNumber)}
                    aria-current={
                      pageNumber === query.page ? 'page' : undefined
                    }
                  >
                    {pageNumber}
                  </a>
                ),
              )}
              {nextPagePath ? (
                <a class="commands-pagination__link" href={nextPagePath}>
                  Next
                </a>
              ) : (
                <span class="commands-pagination__disabled">Next</span>
              )}
            </nav>
          )
        }
      </section>

      {
        hasResults && !isUnavailable && (
          <section class="commands-cta" aria-labelledby="commands-cta-title">
            <h2 id="commands-cta-title">
              Want Santa&apos;s answer to your request?
            </h2>
            <p>Ask once and see what Santa decides.</p>
            <a class="button-command" href="/#ask-santa">
              ASK SANTA
            </a>
          </section>
        )
      }
    </PublicShell>
  </main>
</BaseLayout>
