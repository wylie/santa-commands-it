---
import WorkshopLayout from '@/layouts/WorkshopLayout.astro';
import { getPublicSeasonalPresentation } from '@/server/config/service';
import { getSiteUrl } from '@/server/env';
import { requireWorkshopPageSession } from '@/server/workshop/auth';
import {
  getWorkshopOpenReportCount,
  getWorkshopRulingDetailData,
} from '@/server/workshop/service';
import {
  buildCanonicalRulingUrl,
  buildRulingPath,
  buildRulingSharePayload,
  buildRulingSocialMetadata,
  buildWorkshopRulingSharePreviewImagePath,
} from '@/utils/rulingPages';
import type { PublicRuling } from '@/utils/rulings';

const session = await requireWorkshopPageSession(Astro);

if (session instanceof Response) {
  return session;
}

Astro.response.headers.set('Cache-Control', 'no-store');

const publicId = Astro.params.publicId ?? '';
const detail = await getWorkshopRulingDetailData(
  publicId,
  Astro.request.headers,
);
const openReportCount = await getWorkshopOpenReportCount(Astro.request.headers);
const seasonalPresentation = await getPublicSeasonalPresentation(
  Astro.request.headers,
);

if (!detail) {
  return Astro.redirect('/workshop/rulings?error=not-found');
}

const ruling: PublicRuling = {
  publicId: detail.ruling.publicId,
  displayName: detail.ruling.displayName,
  requestText: detail.ruling.requestText,
  decision: detail.ruling.decision,
  santaResponse: detail.ruling.santaResponse,
  isFeatured: detail.ruling.isFeatured,
  createdAt: detail.ruling.createdAt,
};
const socialMetadata = buildRulingSocialMetadata(ruling, {
  siteUrl: getSiteUrl() ?? Astro.site,
  requestUrl: Astro.url,
});
const canonicalRulingUrl = buildCanonicalRulingUrl(detail.ruling.publicId, {
  siteUrl: getSiteUrl() ?? Astro.site,
  requestUrl: Astro.url,
});
const sharePayload = canonicalRulingUrl
  ? buildRulingSharePayload(ruling, canonicalRulingUrl)
  : null;
const previewImagePath = buildWorkshopRulingSharePreviewImagePath(
  detail.ruling.publicId,
);
const publicShareStatus =
  detail.ruling.visibility !== 'public'
    ? {
        label: 'Not publicly shareable',
        state: 'needs-attention',
        detail:
          'This ruling is hidden, so owners can preview the image privately but visitors should not share it.',
      }
    : !socialMetadata.canonicalUrl
      ? {
          label: 'Needs attention',
          state: 'needs-attention',
          detail:
            'A canonical public ruling URL could not be resolved from the current SITE_URL or safe request origin.',
        }
      : !socialMetadata.imageUrl
        ? {
            label: 'Needs attention',
            state: 'needs-attention',
            detail:
              'The public ruling URL exists, but the public Open Graph image URL could not be resolved.',
          }
        : {
            label: 'Ready to share',
            state: 'healthy',
            detail:
              'This ruling has a public canonical URL, a public image URL, and a deterministic share payload.',
          };

const metadataChecks = [
  {
    label: 'Visibility',
    value: detail.ruling.visibility,
  },
  {
    label: 'Share readiness',
    value: publicShareStatus.label,
  },
  {
    label: 'Metadata title',
    value: socialMetadata.title,
  },
  {
    label: 'Metadata description',
    value: socialMetadata.description,
  },
  {
    label: 'Native share title',
    value: sharePayload?.title ?? 'Unavailable',
  },
  {
    label: 'Native share text',
    value:
      sharePayload?.text ??
      'Unavailable until a canonical public URL is available.',
  },
  {
    label: 'Image alt',
    value: socialMetadata.imageAlt,
  },
  {
    label: 'Image dimensions',
    value: `${socialMetadata.imageWidth} x ${socialMetadata.imageHeight}`,
  },
  {
    label: 'Seasonal mode',
    value: seasonalPresentation.mode,
  },
  {
    label: 'Featured',
    value: detail.ruling.isFeatured ? 'Yes' : 'No',
  },
  {
    label: 'Private preview image',
    value: new URL(previewImagePath, Astro.url).toString(),
  },
  {
    label: 'Canonical ruling URL',
    value: socialMetadata.canonicalUrl ?? 'Unavailable',
  },
  {
    label: 'Public image URL',
    value:
      detail.ruling.visibility === 'public'
        ? (socialMetadata.imageUrl ?? 'Unavailable')
        : 'Hidden rulings do not expose a public share image URL.',
  },
];
---

<WorkshopLayout
  title={`Share Preview for ${detail.ruling.displayName}`}
  description="A private preview of the current ruling share image, canonical URLs, and metadata diagnostics."
  currentPath="/workshop/rulings"
  csrfToken={session.csrfToken}
  openReportCount={openReportCount}
>
  <section class="workshop-grid workshop-grid--detail">
    <article class="workshop-card">
      <div class="workshop-card__header">
        <h2>Share image preview</h2>
        <a
          class="workshop-inline-link"
          href={`/workshop/rulings/${detail.ruling.publicId}`}
        >
          Back to ruling
        </a>
      </div>

      <div
        class={`workshop-share-preview__status is-${publicShareStatus.state}`}
      >
        <strong>{publicShareStatus.label}</strong>
        <p>{publicShareStatus.detail}</p>
      </div>

      <p class="workshop-form__hint">
        This private renderer preview shows the current social image exactly as
        it will appear for public rulings. Hidden rulings stay previewable here
        without exposing a public share URL.
      </p>

      <img
        class="workshop-share-preview__image"
        src={previewImagePath}
        alt={socialMetadata.imageAlt}
        width={socialMetadata.imageWidth}
        height={socialMetadata.imageHeight}
      />

      <div class="workshop-card__section">
        <h3>Share payload</h3>
        <div class="workshop-form workshop-share-preview__fields">
          <div class="workshop-form__field">
            <label for="share-preview-canonical-url">Canonical ruling URL</label
            >
            <input
              id="share-preview-canonical-url"
              type="text"
              readonly
              value={canonicalRulingUrl ?? ''}
            />
          </div>
          <div class="workshop-form__field">
            <label for="share-preview-share-title">Native share title</label>
            <input
              id="share-preview-share-title"
              type="text"
              readonly
              value={sharePayload?.title ?? ''}
            />
          </div>
          <div class="workshop-form__field">
            <label for="share-preview-share-text">Native share text</label>
            <textarea id="share-preview-share-text" rows="4" readonly
              >{sharePayload?.text ?? ''}</textarea
            >
          </div>
        </div>
      </div>
    </article>

    <article class="workshop-card">
      <h2>Share diagnostics</h2>

      <dl class="workshop-detail-list">
        {
          metadataChecks.map((check) => (
            <div>
              <dt>{check.label}</dt>
              <dd>{check.value}</dd>
            </div>
          ))
        }
      </dl>

      {
        detail.ruling.visibility === 'public' && (
          <div class="workshop-card__section">
            <h3>Public ruling</h3>
            <p>
              <a
                class="workshop-inline-link"
                href={buildRulingPath(detail.ruling.publicId)}
              >
                Open public ruling
              </a>
            </p>
          </div>
        )
      }
    </article>
  </section>
</WorkshopLayout>

<style>
  .workshop-share-preview__status {
    display: grid;
    gap: 0.4rem;
    padding: 0.9rem 1rem;
    border: 1px solid rgb(73 99 84 / 0.15);
    border-radius: 1rem;
    background: rgb(255 255 255 / 0.78);
  }

  .workshop-share-preview__status strong,
  .workshop-share-preview__status p {
    margin: 0;
  }

  .workshop-share-preview__status strong {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-evergreen-deep);
  }

  .workshop-share-preview__status.is-needs-attention {
    border-color: rgb(166 83 85 / 0.22);
    background: linear-gradient(180deg, #fffafa, rgb(255 255 255 / 0.96));
  }

  .workshop-share-preview__fields {
    display: grid;
    gap: 0.9rem;
  }

  .workshop-share-preview__fields textarea {
    min-height: 7.5rem;
  }

  .workshop-share-preview__image {
    width: 100%;
    height: auto;
    border-radius: 1.5rem;
    border: 1px solid rgba(39, 67, 55, 0.12);
    box-shadow: 0 1.5rem 3rem rgba(26, 45, 37, 0.12);
  }
</style>
