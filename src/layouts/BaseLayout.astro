---
import { SITE_METADATA, SITE_TITLE } from '@/config/site';
import { getSiteUrl } from '@/server/env';
import { buildCanonicalUrl } from '@/utils/rulingPages';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  canonicalUrl?: string | null;
  ogType?: 'website' | 'article';
  robots?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_METADATA.description,
  canonicalPath = '/',
  canonicalUrl = buildCanonicalUrl(canonicalPath, {
    siteUrl: getSiteUrl(),
    requestUrl: Astro.url,
  }),
  ogType = 'website',
  robots,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Germania+One&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={SITE_METADATA.themeColor} />
    {robots && <meta name="robots" content={robots} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
